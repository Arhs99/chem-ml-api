tests/fixtures/

# Model artifacts — users drop weights into models/, never committed
models/**
!models/.gitkeep
*.pt
*.ckpt

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
.tox/

# Virtualenvs
.venv/
venv/
env/

# IDE / OS
.idea/
.vscode/
.DS_Store
